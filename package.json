{
  "name": "afrilab",
  "version": "1.0.0",
  "description": "Africa's foremost simulated science laboratory platform",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "preview:wrangler": "wrangler pages dev .svelte-kit/cloudflare",
    "deploy": "npm run build && wrangler pages deploy .svelte-kit/cloudflare",
    "db:migrate": "wrangler d1 execute afrilab-db --local --file=./migrations/0001_initial_schema.sql",
    "db:migrate:prod": "wrangler d1 execute afrilab-db --file=./migrations/0001_initial_schema.sql",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@types/three": "^0.182.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.5",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@sveltejs/adapter-cloudflare": "^4.7.4",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "@testing-library/svelte": "^5.3.1",
    "autoprefixer": "^10.4.20",
    "jsdom": "^27.4.0",
    "postcss": "^8.4.49",
    "svelte": "^5.2.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^4.0.17",
    "wrangler": "^3.91.0"
  }
}
